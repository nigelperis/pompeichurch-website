---
import { Image } from "astro:assets";
import { Locale } from "~/enums/locale";
import { cn } from "~/helpers/cn";
import { getLangFromUrl } from "~/i18n/utils";
import NetworkImage from "~/components/ui/network-image.astro";
import placeholderImage from "~/assets/static-assets/blank.jpeg";
import { TermNumberLabel } from "~/enums/term-number";
import { renderEndDate, formatDate } from "~/helpers/term-utils";

const lang = getLangFromUrl(Astro.url);

interface Props {
  name: string;
  imageUrl?: string;
  subtitle?: string;
  class?: string;
  terms?: { termNo: number; startDate: string; endDate: string | null }[];
}

const { name, class: className, imageUrl, terms } = Astro.props;
---

<div
  class={cn(
    "snap-start first:snap-align-none max-w-xs flex-shrink-0 border border-gray-200 sm:w-64",
    className,
    "w-[250px] h-auto md:h-[440px]",
  )}
>
  <div class="flex-none">
    {
      imageUrl ? (
        <NetworkImage
          src={imageUrl}
          alt={name}
          width={600}
          height={400}
          class="h-[300px] w-full object-cover"
        />
      ) : (
        <Image
          src={placeholderImage}
          alt="Blank Profile Image"
          width={600}
          height={400}
          class="h-[300px] w-full object-cover"
        />
      )
    }
  </div>

  <div
    class={cn("flex flex-1 flex-col justify-end space-y-1 p-3", {
      "font-bold": lang === Locale.KOK,
    })}
  >
    <h3
      class="pt-1 font-bold leading-snug text-blue-800 sm:text-lg"
      title={name}
    >
      {name}
    </h3>
    {
      terms &&
        [...terms]
          .sort((a, b) => b.termNo - a.termNo)
          .map((term) => (
            <p class="text-black">
              <b>{TermNumberLabel[term.termNo]}</b> :
              <span class="font-semibold text-red-400">
                {formatDate(term.startDate)} :{" "}
                {renderEndDate(term.endDate, lang)}
              </span>
            </p>
          ))
    }
  </div>
</div>
