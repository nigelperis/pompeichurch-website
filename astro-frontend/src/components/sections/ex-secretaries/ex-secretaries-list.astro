---
import { Locale } from "~/enums/locale";
import { getLangFromUrl } from "~/i18n/utils";
import { listExVicePresidentsAndSecretaries } from "~/services/list-ex-vice-presidents-and-secretaries-data";
import VpsecCard from "~/components/vpsec-card.astro";
import { ExOfficeBearersRole } from "~/enums/ex-office-bearers-role";
import { Message } from "~/constants/message.ts";

const lang = getLangFromUrl(Astro.url);

const secretaries = await listExVicePresidentsAndSecretaries({
  page: 1,
  pageSize: 100,
  filters: { role: { $eq: ExOfficeBearersRole.SECRETARY } },
});
---

<div
  class="grid-cols-1 mx-auto grid w-full gap-x-20 gap-y-5 pt-6 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3"
>
  {
    secretaries.length > 0 ? (
      secretaries.map((sec) => (
        <VpsecCard
          class="m-auto"
          imageUrl={
            sec.image?.url &&
            new URL(sec.image.url, import.meta.env.PUBLIC_STRAPI_URL).toString()
          }
          imageWidth={sec.image?.width}
          imageHeight={sec.image?.height}
          name={lang === Locale.KOK ? sec.nameKok : sec.nameEn}
          terms={sec.terms}
        />
      ))
    ) : (
      <p class="col-span-full py-8 text-center text-3xl font-semibold">
        {lang === Locale.KOK
          ? Message.SECRETARIES_NOT_FOUND_KOK
          : Message.SECRETARIES_NOT_FOUND}
      </p>
    )
  }
</div>
