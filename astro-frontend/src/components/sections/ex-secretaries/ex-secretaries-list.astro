---

import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import { listExVicePresidentsAndSecretaries } from "~/services/list-ex-vice-presidents-and-secretaries-data";
import VpsecCard from "~/components/vpsec-card.astro";
import { ExOfficeBearersRole } from "~/enums/ex-office-bearers-role";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const secretaries = await listExVicePresidentsAndSecretaries({
  page: 1,
  pageSize: 100,
  filters: { role: {$eq: ExOfficeBearersRole.SECRETARY} },
})
---

<div
  class="grid-cols-1 mx-auto grid w-full gap-x-20 gap-y-10 pt-6 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3"
>
  {
    secretaries.map((sec) => (
      <VpsecCard
        imageUrl={
           sec.image?.url &&
           new URL(
              sec.image.url,
              import.meta.env.PUBLIC_STRAPI_URL
          ).toString()
        }
        name={lang === "kok" ? sec.nameKok : sec.nameEn}
        term={
          sec.terms?.[0]
            ? `${sec.terms[0].startDate} : ${sec.terms[0].endDate}`
            : undefined
        }

        term2={
          sec.terms?.[1]
            ? `${sec.terms[1].startDate} : ${sec.terms[1].endDate}`
            : undefined
        }




      />
    ))
  }
</div>
