---
import { getLangFromUrl, useTranslations } from '~/i18n/utils';
import VocationCard from '~/components/vocation-card.astro';
import { religiousVocations } from '~/constants/religious-vocations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
	class="mx-auto grid w-full grid-cols-2 gap-x-20 gap-y-10 pt-10 xs:grid-cols-1 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3"
>
	{
		religiousVocations.map((religious) => (
			<VocationCard
        imageUrl={religious.imageUrl}
				name={religious.name}
        ward={religious.ward}
				dob={religious.dob}
        dod={religious.dod}
        congregation={religious.congregation}
        parents={religious.parents}
			/>
		))
	}
</div>
