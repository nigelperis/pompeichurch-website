---

import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import { ExOfficeBearersRole } from "~/enums/ex-office-bearers-role";
import VpsecCard from "~/components/vpsec-card.astro";
import { listExVicePresidentsAndSecretaries } from "~/services/list-ex-vice-presidents-and-secretaries-data";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const treasurers = await listExVicePresidentsAndSecretaries({
  page: 1,
  pageSize: 100,
  filters: { role: {$eq: ExOfficeBearersRole.TREASURER} },
});

---

<div
  class="grid-cols-1 mx-auto grid w-full gap-x-20 gap-y-10 pt-6 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3"
>
  {
    treasurers.map((treasurer) => (
      <VpsecCard
        class="m-auto"
        imageUrl={
          treasurer.image?.url &&
          new URL(
            treasurer.image.url,
            import.meta.env.PUBLIC_STRAPI_URL
          ).toString()
        }
        name={lang === "kok" ? treasurer.nameKok : treasurer.nameEn}

      />
    ))
  }
</div>
