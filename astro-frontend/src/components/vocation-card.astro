---
import { Image } from "astro:assets";
import { cn } from "~/helpers/cn";
import { getLangFromUrl, useTranslations } from "~/i18n/utils";
import { ReligiousVocationRole } from "~/enums/religious-vocation-role";
import placeholderImage from "~/assets/static-assets/blank.jpeg";

export interface Props {
  imageUrl?: string;
  imageWidth?: number;
  imageHeight?: number;
  name: string;
  ward: string;
  dob?: string;
  dod?: string;
  congregation?: string;
  parents?: string;
  role?: ReligiousVocationRole;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const {
  imageUrl,
  imageWidth,
  imageHeight,
  name,
  ward,
  dob,
  dod,
  congregation,
  parents,
  role,
} = Astro.props;
---

<div
  class="mx-auto w-full max-w-md border border-gray-200 p-5 text-center md:w-full lg:w-auto"
>
  <div
    class="relative mx-auto mb-6 h-[300px] w-[230px] overflow-hidden rounded-full border-4 border-gray-200 shadow-md md:h-[280px] md:w-[210px]"
  >
    {
      imageUrl ? (
        <Image
          src={imageUrl}
          alt={name}
          class="h-full w-full object-cover"
          width={imageWidth ?? 230}
          height={imageHeight ?? 300}
        />
      ) : (
        <Image
          src={placeholderImage}
          alt="Blank Profile Image"
          class="h-full w-full object-cover"
        />
      )
    }
  </div>

  <div class={cn({ "font-bold": lang === "kok" })}>
    <h3 class="mb-2 text-lg font-semibold text-red-700 lg:text-xl">{name}</h3>
    {
      congregation && role && (
        <p class="mb-2 font-medium text-blue-700 lg:text-sm">{congregation}</p>
      )
    }
    {
      ward && (
        <p class="mb-1 italic text-slate-700 lg:text-sm">
          <span class="font-semibold">{t("vocation.ward")}</span> {ward}
        </p>
      )
    }
    {
      dob && (
        <p class="mb-1 text-slate-700 lg:text-sm">
          <span class="font-semibold">{t("vocation.dob")}</span> {dob}
        </p>
      )
    }
    {
      dod && (
        <p class="mb-1 text-slate-700 lg:text-sm">
          <span class="font-semibold">{t("vocation.dod")}</span> {dod}
        </p>
      )
    }
    {
      parents && role && (
        <p class="mb-1 text-slate-700 lg:text-sm">
          <span class="font-semibold">
            {role === ReligiousVocationRole.NUN
              ? t("vocation.do")
              : t("vocation.so")}
          </span>
          {parents}
        </p>
      )
    }
  </div>
</div>
