---
import { getMagazineBySlug } from "~/services/list-magazines";
import {
  getMagazineCoverImage,
  getMagazineDisplayTitle,
} from "~/helpers/magazine";
import { getLangFromUrl, useTranslations } from "~/i18n/utils";

const { slug } = Astro.params;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const magazine = await getMagazineBySlug(slug ?? "");

if (!magazine) {
  throw new Error("Magazine not found");
}

const fileUrl = new URL(
  magazine.pdfFile.url,
  import.meta.env.PUBLIC_STRAPI_URL,
).toString();

const coverImage = getMagazineCoverImage(magazine);
const imageUrl = new URL(
  coverImage.url,
  import.meta.env.PUBLIC_STRAPI_URL,
).toString();

const displayTitle = getMagazineDisplayTitle(magazine, lang);
const metaDescription = t("magazine.view.description");
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{displayTitle}</title>

    <meta property="og:title" content={displayTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={displayTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={imageUrl} />

    <meta http-equiv="refresh" content={`0;url=${fileUrl}`} />
  </head>
  <body></body>
</html>
