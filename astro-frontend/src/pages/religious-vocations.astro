---
import Layout from '~/layouts/layout.astro';
import { getLangFromUrl, useTranslations } from '~/i18n/utils';
import ReligiousVocationsList from '~/components/sections/religious-vocations/religious-vocations-list.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="Pompei Church | Religious Vocations">
	<main class="mx-auto max-w-4xl overflow-hidden bg-white">
		<section id="parish-priests" class="flex flex-col p-6 pb-4">
			<h1
				class="mb-4 border-l-4 border-natgeo-yellow pl-3 text-3xl font-extrabold lg:text-4xl"
			>
				{t('nav.religious-vocations')}
			</h1>
			<p class="text-justify font-geist text-lg text-slate-700">
				A Glimpse of Our Parishioners: Those who have answered His call, embraced religious vocations, and are now spreading God's kingdom.
			</p>
			<ReligiousVocationsList />
		</section>
	</main>
</Layout>
